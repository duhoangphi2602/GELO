# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/gelo_db?schema=public

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
CORS_ORIGIN=http://localhost:5173
MAX_BODY_SIZE=15mb

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h

# ─── AI Service ──────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
INTERNAL_API_KEY=

# ─── Cloudinary (upload ảnh quét da) ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email OTP ───────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM="GELO Healthcare" <noreply@gelo.com>

# ─── Ngưỡng nghiệp vụ ────────────────────────────────────────────────────────
LOW_CONFIDENCE_THRESHOLD=60
AUTO_TRAIN_THRESHOLD=85
