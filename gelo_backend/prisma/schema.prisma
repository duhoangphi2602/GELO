generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id           Int      @id @default(autoincrement()) @map("account_id")
  username     String   @unique @db.VarChar(100)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  isVerified   Boolean  @default(false) @map("is_verified")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  role         UserRole @default(PATIENT)
  patient      Patient?
}

model Patient {
  id        Int         @id @default(autoincrement()) @map("patient_id")
  accountId Int         @unique @map("account_id")
  fullName  String?     @map("full_name") @db.VarChar(100)
  age       Int?
  createdAt DateTime    @default(now()) @map("created_at")
  gender    Gender?     @default(UNKNOWN)
  account   Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  diaries   SkinDiary[]
  skinScans SkinScan[]
}

model Disease {
  id                 Int               @id @default(autoincrement()) @map("disease_id")
  code               String            @unique @db.VarChar(50)
  name               String            @db.VarChar(100)
  description        String?
  diagnosisFinal     DiagnosisResult[] @relation("FinalDisease")
  diagnosisPredicted DiagnosisResult[] @relation("PredictedDisease")
  advices            DiseaseAdvice[]
  images             DiseaseImage[]
  feedbackActual     FeedbackLog[]     @relation("ActualDiseaseFeedback")
  feedbackPredicted  FeedbackLog[]     @relation("PredictedDiseaseFeedback")
  predictions        Prediction[]
}

model DiseaseImage {
  id        Int      @id @default(autoincrement()) @map("image_id")
  diseaseId Int?     @map("disease_id")
  scanId    Int?     @map("scan_id")
  imageUrl  String   @map("image_url") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  disease   Disease? @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  scan      SkinScan? @relation(fields: [scanId], references: [id], onDelete: Cascade)
}

model DiseaseAdvice {
  id         Int      @id @default(autoincrement()) @map("advice_id")
  diseaseId  Int?     @map("disease_id")
  adviceType String   @map("advice_type") @db.VarChar(20)
  title      String   @db.VarChar(255)
  content    String
  priority   Int?
  disease    Disease? @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
}

model SkinScan {
  id          Int              @id @default(autoincrement()) @map("scan_id")
  patientId   Int              @map("patient_id")
  imageQuality ImageQuality    @default(CLEAR) @map("image_quality")
  createdAt   DateTime         @default(now()) @map("created_at")
  isDeleted   Boolean          @default(false) @map("is_deleted")
  diagnosis   DiagnosisResult?
  feedback    FeedbackLog[]
  predictions Prediction[]
  images      ScanImage[]
  diseaseImages DiseaseImage[]
  diaries     SkinDiary[]
  patient     Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model ScanImage {
  id        Int      @id @default(autoincrement()) @map("image_id")
  scanId    Int      @map("scan_id")
  imageUrl  String   @map("image_url") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")
  scan      SkinScan @relation(fields: [scanId], references: [id], onDelete: Cascade)
}

model Prediction {
  id               Int              @id @default(autoincrement()) @map("prediction_id")
  scanId           Int?             @map("scan_id")
  diseaseId        Int?             @map("disease_id")
  /// AI confidence stored as 0–100 (percentage)
  confidence       Float?
  modelVersion     String?          @map("model_version") @db.VarChar(255)
  createdAt        DateTime         @default(now()) @map("created_at")
  diagnosticStatus DiagnosticStatus @default(DISEASE) @map("diagnostic_status")
  disease          Disease?         @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  scan             SkinScan?        @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@index([confidence])
}

model DiagnosisResult {
  id                 Int              @id @default(autoincrement()) @map("result_id")
  scanId             Int              @unique @map("scan_id")
  predictedDiseaseId Int?             @map("predicted_disease_id")
  finalDiseaseId     Int?             @map("final_disease_id")
  createdAt          DateTime         @default(now()) @map("created_at")
  /// "high_confidence" (>=50%) | "low_confidence" (<50%)
  decision           String?          @db.VarChar(50)
  /// AI confidence stored as 0–100 (percentage)
  aiConfidence       Float?           @map("ai_confidence")
  diagnosticStatus   DiagnosticStatus @default(DISEASE) @map("diagnostic_status")
  finalDisease       Disease?         @relation("FinalDisease", fields: [finalDiseaseId], references: [id], onDelete: Cascade)
  predictedDisease   Disease?         @relation("PredictedDisease", fields: [predictedDiseaseId], references: [id], onDelete: Cascade)
  scan               SkinScan         @relation(fields: [scanId], references: [id], onDelete: Cascade)
}

model FeedbackLog {
  id                 Int              @id @default(autoincrement()) @map("feedback_id")
  scanId             Int?             @map("scan_id")
  predictedDiseaseId Int?             @map("predicted_disease_id")
  actualDiseaseId    Int?             @map("actual_disease_id")
  isCorrect          Boolean?         @map("is_correct")
  note               String?
  createdAt          DateTime         @default(now()) @map("created_at")
  diagnosticStatus   DiagnosticStatus @default(DISEASE) @map("diagnostic_status")
  role               FeedbackRole     @default(USER)
  actualDisease      Disease?         @relation("ActualDiseaseFeedback", fields: [actualDiseaseId], references: [id], onDelete: Cascade)
  predictedDisease   Disease?         @relation("PredictedDiseaseFeedback", fields: [predictedDiseaseId], references: [id], onDelete: Cascade)
  scan               SkinScan?        @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
}

model SkinDiary {
  id             Int       @id @default(autoincrement()) @map("diary_id")
  patientId      Int       @map("patient_id")
  scanId         Int?      @map("scan_id")
  conditionScore Int?      @map("condition_score")
  symptoms       String[]  @default([])
  note           String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")
  patient        Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  scan           SkinScan? @relation(fields: [scanId], references: [id], onDelete: Cascade)
}

enum UserRole {
  ADMIN
  PATIENT
}

enum FeedbackRole {
  USER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

enum DiagnosticStatus {
  DISEASE
  UNKNOWN
  HEALTHY
}

model OtpCode {
  id        Int      @id @default(autoincrement()) @map("otp_id")
  email     String   @db.VarChar(255)
  code      String   @db.VarChar(6)
  type      OtpType
  expiresAt DateTime @map("expires_at")
  attempts  Int      @default(0)
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email, type])
}

enum OtpType {
  REGISTER
  FORGOT_PASSWORD
  CHANGE_PASSWORD
}

enum ImageQuality {
  CLEAR
  BLURRY
}
