generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id           Int      @id @default(autoincrement()) @map("account_id")
  username     String   @unique @db.VarChar(100)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         UserRole @default(PATIENT)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  patient      Patient?
}

model Patient {
  id        Int         @id @default(autoincrement()) @map("patient_id")
  accountId Int         @unique @map("account_id")
  fullName  String?     @map("full_name") @db.VarChar(100)
  age       Int?
  gender    Gender?     @default(UNKNOWN)
  createdAt DateTime    @default(now()) @map("created_at")
  account   Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  diaries   SkinDiary[]
  skinScans SkinScan[]
}

model Disease {
  id                 Int               @id @default(autoincrement()) @map("disease_id")
  name               String            @unique @db.VarChar(100)
  description        String?
  diagnosisFinal     DiagnosisResult[] @relation("FinalDisease")
  diagnosisPredicted DiagnosisResult[] @relation("PredictedDisease")
  advices            DiseaseAdvice[]
  images             DiseaseImage[]
  rules              DiseaseRule[]
  feedbackActual     FeedbackLog[]     @relation("ActualDiseaseFeedback")
  feedbackPredicted  FeedbackLog[]     @relation("PredictedDiseaseFeedback")
  predictions        Prediction[]
}

model DiseaseImage {
  id        Int      @id @default(autoincrement()) @map("image_id")
  diseaseId Int?     @map("disease_id")
  imageUrl  String?  @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")
  scanId    Int?     @map("scan_id")
  disease   Disease? @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
}

model DiagnosticQuestion {
  id           Int            @id @default(autoincrement()) @map("question_id")
  questionText String?        @map("question_text")
  createdAt    DateTime       @default(now()) @map("created_at")
  isActive     Boolean?       @default(true) @map("is_active")
  isEmergency  Boolean?       @default(false) @map("is_emergency")
  rules        DiseaseRule[]
  scoreLogs    RuleScoreLog[]
}

model DiseaseRule {
  id             Int                 @id @default(autoincrement()) @map("rule_id")
  diseaseId      Int?                @map("disease_id")
  questionId     Int?                @map("question_id")
  expectedAnswer Boolean?            @map("expected_answer")
  weight         Float?
  isActive       Boolean?            @default(true) @map("is_active")
  disease        Disease?            @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  question       DiagnosticQuestion? @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model DiseaseAdvice {
  id         Int      @id @default(autoincrement()) @map("advice_id")
  diseaseId  Int?     @map("disease_id")
  adviceType String?  @map("advice_type") @db.VarChar(20)
  title      String?  @db.VarChar(255)
  content    String?
  priority   Int?
  disease    Disease? @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
}

model SkinScan {
  id            Int              @id @default(autoincrement()) @map("scan_id")
  patientId     Int              @map("patient_id")
  createdAt     DateTime         @default(now()) @map("created_at")
  diagnosis     DiagnosisResult?
  feedback      FeedbackLog[]
  predictions   Prediction[]
  ruleScoreLogs RuleScoreLog[]
  images        ScanImage[]
  diaries       SkinDiary[]
  patient       Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model ScanImage {
  id        Int      @id @default(autoincrement()) @map("image_id")
  scanId    Int      @map("scan_id")
  imageUrl  String   @map("image_url") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")
  scan      SkinScan @relation(fields: [scanId], references: [id], onDelete: Cascade)
}

model Prediction {
  id               Int              @id @default(autoincrement()) @map("prediction_id")
  scanId           Int?             @map("scan_id")
  diseaseId        Int?             @map("disease_id")
  confidence       Float?
  modelVersion     String?          @map("model_version") @db.VarChar(255)
  createdAt        DateTime         @default(now()) @map("created_at")
  diagnosticStatus DiagnosticStatus @default(DISEASE) @map("diagnostic_status")
  disease          Disease?  @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  scan             SkinScan? @relation(fields: [scanId], references: [id], onDelete: Cascade)
}

model DiagnosisResult {
  id                 Int              @id @default(autoincrement()) @map("result_id")
  scanId             Int              @unique @map("scan_id")
  predictedDiseaseId Int?             @map("predicted_disease_id")
  finalDiseaseId     Int?             @map("final_disease_id")
  isEmergency        Boolean?         @map("is_emergency")
  createdAt          DateTime         @default(now()) @map("created_at")
  decision           String?          @db.VarChar(50)
  maxRuleScore       Float?           @map("max_rule_score")
  normalizedScore    Float?           @map("normalized_score")
  ruleScore          Float?           @map("rule_score")
  diagnosticStatus   DiagnosticStatus @default(DISEASE) @map("diagnostic_status")
  finalDisease       Disease? @relation("FinalDisease", fields: [finalDiseaseId], references: [id], onDelete: Cascade)
  predictedDisease   Disease? @relation("PredictedDisease", fields: [predictedDiseaseId], references: [id], onDelete: Cascade)
  scan               SkinScan @relation(fields: [scanId], references: [id], onDelete: Cascade)
}

model FeedbackLog {
  id                 Int              @id @default(autoincrement()) @map("feedback_id")
  scanId             Int?             @map("scan_id")
  predictedDiseaseId Int?             @map("predicted_disease_id")
  actualDiseaseId    Int?             @map("actual_disease_id")
  isCorrect          Boolean?         @map("is_correct")
  note               String?
  createdAt          DateTime         @default(now()) @map("created_at")
  diagnosticStatus   DiagnosticStatus @default(DISEASE) @map("diagnostic_status")
  actualDisease      Disease?  @relation("ActualDiseaseFeedback", fields: [actualDiseaseId], references: [id], onDelete: Cascade)
  predictedDisease   Disease?  @relation("PredictedDiseaseFeedback", fields: [predictedDiseaseId], references: [id], onDelete: Cascade)
  scan               SkinScan? @relation(fields: [scanId], references: [id], onDelete: Cascade)
}

model SkinDiary {
  id             Int       @id @default(autoincrement()) @map("diary_id")
  patientId      Int       @map("patient_id")
  scanId         Int?      @map("scan_id")
  conditionScore Int?      @map("condition_score")
  note           String?
  createdAt      DateTime  @default(now()) @map("created_at")
  patient        Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  scan           SkinScan? @relation(fields: [scanId], references: [id], onDelete: Cascade)
}

model RuleScoreLog {
  id                Int                @id @default(autoincrement()) @map("log_id")
  scanId            Int                @map("scan_id")
  questionId        Int                @map("question_id")
  patientAnswer     String             @map("patient_answer") @db.VarChar(20)
  expectedAnswer    Boolean?           @map("expected_answer")
  isMatch           Boolean            @map("is_match")
  weight            Float
  scoreContribution Float              @map("score_contribution")
  createdAt         DateTime           @default(now()) @map("created_at")
  question          DiagnosticQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  scan              SkinScan           @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
}

enum UserRole {
  ADMIN
  PATIENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

enum DiagnosticStatus {
  DISEASE
  HEALTHY
  UNKNOWN
}
